{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/chatbot run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/server.js": {
      "includeFiles": "../../api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
