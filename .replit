modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c 'PORT=8080 pnpm --filter @workspace/api-server run dev & API_PID=$!; PORT=5000 API_PORT=8080 pnpm --filter @workspace/chatbot run dev; STATUS=$?; kill $API_PID 2>/dev/null || true; wait $API_PID 2>/dev/null || true; exit $STATUS'"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 22967
externalPort = 3000
